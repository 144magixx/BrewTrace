{
  "type": "json_schema",
  "name": "coffee_model_message_v2",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["messageType", "talk", "conversation", "post", "factUpdates", "warnings"],
    "properties": {
      "messageType": {"type": "string", "enum": ["CONVERSATION", "POST"]},
      "talk": {"type": "string", "minLength": 1},
      "conversation": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["questions", "answerOptions", "pendingConfirmations", "warnings"],
        "properties": {
          "questions": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"type": "string"}},
          "answerOptions": {"type": "array", "maxItems": 4, "items": {"$ref": "#/$defs/answerOption"}},
          "pendingConfirmations": {"$ref": "#/$defs/usageArray"},
          "warnings": {"type": "array", "maxItems": 20, "items": {"type": "string"}}
        }
      },
      "post": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["variants", "warnings"],
        "properties": {
          "variants": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/variant"}},
          "warnings": {"type": "array", "maxItems": 20, "items": {"type": "string"}}
        }
      },
      "factUpdates": {
        "type": "array",
        "maxItems": 20,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["action", "boundary", "value", "sourceMessageId", "sourceQuote", "reason", "targetItemId"],
          "properties": {
            "action": {"type": "string", "enum": ["ADD_CONFIRMED_FACT", "ADD_PENDING_ASSOCIATION", "ACCEPT_PENDING_ASSOCIATION", "REJECT_PENDING_ASSOCIATION", "REVISE_CONFIRMED_FACT", "WITHDRAW_CONFIRMED_FACT"]},
            "boundary": {"type": "string", "enum": ["USER_STATED", "USER_CONFIRMED", "USER_UNCERTAIN", "MODEL_INFERRED", "PENDING_ASSOCIATION", "USER_REJECTED"]},
            "value": {"type": "string", "minLength": 1, "maxLength": 500},
            "sourceMessageId": {"type": "string", "minLength": 1, "maxLength": 100},
            "sourceQuote": {"type": "string", "minLength": 1, "maxLength": 500},
            "reason": {"type": "string", "minLength": 1, "maxLength": 1000},
            "targetItemId": {"type": ["string", "null"], "maxLength": 100}
          }
        }
      },
      "warnings": {"type": "array", "maxItems": 20, "items": {"type": "string"}}
    },
    "$defs": {
      "answerOption": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "content"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "content": {"type": "string"}
        }
      },
      "variant": {
        "type": "object",
        "additionalProperties": false,
        "required": ["style", "styleLabel", "title", "body", "tags", "factUsages", "inferences", "pendingConfirmations", "warnings"],
        "properties": {
          "style": {"type": "string", "enum": ["RESTRAINED", "EXAGGERATED", "SHARP_REVIEW"]},
          "styleLabel": {"type": "string"},
          "title": {"type": "string"},
          "body": {"type": "string"},
          "tags": {"type": "array", "maxItems": 20, "items": {"type": "string"}},
          "factUsages": {"$ref": "#/$defs/usageArray"},
          "inferences": {"$ref": "#/$defs/usageArray"},
          "pendingConfirmations": {"$ref": "#/$defs/usageArray"},
          "warnings": {"type": "array", "maxItems": 20, "items": {"type": "string"}}
        }
      },
      "usageArray": {
        "type": "array",
        "maxItems": 20,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["expression", "basisType", "sourceReference", "sourceId", "confidenceLabel"],
          "properties": {
            "expression": {"type": "string"},
            "basisType": {"type": "string"},
            "sourceReference": {"type": "string"},
            "sourceId": {"type": "string"},
            "confidenceLabel": {"type": "string"}
          }
        }
      }
    }
  }
}

